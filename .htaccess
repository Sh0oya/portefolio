# .htaccess for mathieuhaye.fr (IONOS Web Plus / Apache)
# IMPORTANT: set this file to permissions 644 on the server
#            (sinon Apache renvoie 403 sur tout le site).

DirectoryIndex index.html

# MultiViews OFF : sinon mod_negotiation sert le jumeau .md aux clients en
# Accept: */* (curl, scrapers sociaux, fetch) a la place du HTML (sans OG,
# canonical ni JSON-LD). La negociation markdown est geree par mod_rewrite.
Options -MultiViews

# ==========================================
# Protect sensitive files (credentials must never be served)
# ==========================================
<FilesMatch "^(google-sa\.json|\.index-state\.json)$">
    Require all denied
</FilesMatch>

# Log files (leads & scans) must never be served over the web.
# Belt and braces: api/data/.htaccess already denies the whole directory.
<FilesMatch "\.jsonl$">
    Require all denied
</FilesMatch>

# ==========================================
# CLEAN URLs + Markdown content negotiation
# ==========================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 00. Force HTTPS (301) : le miroir http:// servait la page en clair.
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # 0. Renamed pages (301 permanent) - keep old links alive
    RewriteRule ^comment-on-bosse/?$ /collaboration [R=301,L]
    RewriteRule ^en/how-i-work/?$ /en/collaboration [R=301,L]

    # 0b. Shareable AI-visibility scan results: /r/<token> -> r.php
    RewriteRule ^r/([A-Za-z0-9_-]+)/?$ /r.php?d=$1 [L,QSA]

    # 0c. Back office prive: /admin -> admin.php (login requis, noindex)
    RewriteRule ^admin/?$ /admin.php [L]

    # 1. Redirect /page.html to /page (301 permanent, browsers + agents)
    RewriteCond %{THE_REQUEST} ^[A-Z]+\s/+(.+)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # 2. Markdown negotiation (RFC 9110 content negotiation pattern):
    #    if Accept: text/markdown and a sibling .md file exists, serve it.
    #    Browsers (Accept: text/html) still get the HTML version below.
    RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
    RewriteCond %{REQUEST_URI} ^/$
    RewriteRule ^$ index.md [L,T=text/markdown]

    # 2b. Home EN /en/ -> en/index.md (la regle generique testerait "en.md")
    RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
    RewriteCond %{REQUEST_URI} ^/en/?$
    RewriteRule ^ en/index.md [L,T=text/markdown]

    RewriteCond %{HTTP_ACCEPT} text/markdown [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.md -f
    RewriteRule ^(.+?)/?$ $1.md [L,T=text/markdown]

    # 3. Internal rewrite: /page -> /page.html (HTML default for browsers)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ==========================================
# MIME types
# ==========================================
AddType text/markdown .md
AddType application/manifest+json .webmanifest
AddType application/xml .xml
AddType text/xml .xsl
AddType application/rss+xml .xml
AddType application/vnd.microsoft.portable-executable .exe
AddType application/zip .zip
<Files "sitemap.xml">
    ForceType application/xml
</Files>
<Files "feed.xml">
    ForceType application/rss+xml
</Files>
<Files "api-catalog">
    ForceType application/linkset+json
</Files>
<Files "oauth-protected-resource">
    ForceType application/json
</Files>
<Files "oauth-authorization-server">
    ForceType application/json
</Files>
<Files "openid-configuration">
    ForceType application/json
</Files>

# ==========================================
# Agent-discovery Link headers (RFC 8288 / RFC 9727)
# Advertises agent resources on every response.
# ==========================================
<IfModule mod_headers.c>
    # Site-wide signal that the response can be negotiated to markdown.
    Header set Vary "Accept"

    # AI usage preferences (Content Signals / AI Preferences draft) sent as a
    # response header so robots.txt validators stay clean. Policy: AI search and
    # assistants may read and answer; training is not permitted.
    Header set Content-Signal "search=yes, ai-input=yes, ai-train=no"

    # RFC 8288 Link headers for agent discovery.
    Header set Link "</.well-known/api-catalog>; rel=\"api-catalog\"; type=\"application/linkset+json\""
    Header add Link "</llms.txt>; rel=\"llms-full\"; type=\"text/plain\""
    Header add Link "</index.md>; rel=\"alternate\"; type=\"text/markdown\""
    Header add Link "</sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\""
    Header add Link "</feed.xml>; rel=\"alternate\"; type=\"application/rss+xml\"; title=\"Mathieu Haye Journal RSS feed\""
    Header add Link "</.well-known/agent-skills/index.json>; rel=\"agent-skills\"; type=\"application/json\""
    Header add Link "</.well-known/mcp/server-card.json>; rel=\"mcp-server\"; type=\"application/json\""
    Header add Link "</.well-known/oauth-protected-resource>; rel=\"oauth-protected-resource\"; type=\"application/json\""
    Header add Link "</robots.txt>; rel=\"robots\"; type=\"text/plain\""

    # Markdown responses get the right Content-Type even when served from rewrite.
    <FilesMatch "\.md$">
        Header set Content-Type "text/markdown; charset=UTF-8"
    </FilesMatch>

    # ===== CORS for agent-readable resources =====
    # Allow any agent (Claude.ai, ChatGPT, custom crawlers) to fetch these
    # cross-origin. Read-only public data only.
    <FilesMatch "\.(md|txt|xml|json|webmanifest)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
        Header set Access-Control-Allow-Headers "Accept, Content-Type, Range, If-Modified-Since"
        Header set Access-Control-Max-Age "86400"
    </FilesMatch>
    <Files "api-catalog">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    </Files>
    <Files "oauth-protected-resource">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    </Files>
    <Files "oauth-authorization-server">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    </Files>
    <Files "security.txt">
        Header set Access-Control-Allow-Origin "*"
    </Files>
    <Files "humans.txt">
        Header set Access-Control-Allow-Origin "*"
    </Files>

    # ===== Security headers (light, no breaking CSP) =====
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
    # Clickjacking: modern (CSP frame-ancestors, same-origin framing kept for the
    # local preview) + legacy fallback (X-Frame-Options) for older browsers.
    Header set Content-Security-Policy "frame-ancestors 'self'"
    Header set X-Frame-Options "SAMEORIGIN"
    # Window isolation: a tab opened by the site (e.g. the booking link) cannot
    # reach window.opener, which blocks reverse-tabnabbing and cross-window leaks.
    Header set Cross-Origin-Opener-Policy "same-origin"
    # Strict Transport Security: force HTTPS for 1 year, subdomains included.
    # (Add "; preload" and submit to hstspreload.org only if you commit to HTTPS forever.)
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Private application page (moet-hennessy, FR + EN share the filename):
    # enforce noindex at the HTTP layer, reinforcing the <meta robots noindex>.
    <FilesMatch "^moet-hennessy\.html$">
        Header set X-Robots-Tag "noindex, nofollow"
    </FilesMatch>

    # Back office (/admin -> admin.php): never indexed. The PHP file sends the
    # same header itself; this is belt and braces at the Apache layer.
    <FilesMatch "^admin\.php$">
        Header set X-Robots-Tag "noindex, nofollow"
        # Authoritative strict headers for the back office. The global block above
        # uses "Header set", which would otherwise clobber the CSP admin.php sends
        # itself; re-setting here (more specific, applied last) wins.
        Header set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' fonts.googleapis.com; font-src fonts.gstatic.com; img-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        Header set Referrer-Policy "no-referrer"
    </FilesMatch>

    # Force "Save As" + correct MIME for binary downloads (no inline execution attempt).
    <FilesMatch "\.exe$">
        Header set Content-Type "application/vnd.microsoft.portable-executable"
        Header set Content-Disposition "attachment"
        Header set X-Content-Type-Options "nosniff"
        Header set X-Robots-Tag "noindex"
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.zip$">
        Header set Content-Type "application/zip"
        Header set Content-Disposition "attachment"
        Header set X-Content-Type-Options "nosniff"
        Header set X-Robots-Tag "noindex"
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
    # SHA-256 sidecar files: tiny, public, cacheable.
    <FilesMatch "\.sha256$">
        Header set Content-Type "text/plain; charset=UTF-8"
        Header set Access-Control-Allow-Origin "*"
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # Short-lived caching for agent-discovery files so audits never hit a stale copy.
    <Files "robots.txt">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </Files>
    <FilesMatch "(api-catalog|oauth-protected-resource|nlweb\.json|server-card\.json|index\.json|security\.txt|humans\.txt)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>
</IfModule>

# ==========================================
# Compression (gzip)
# ==========================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml text/markdown application/javascript application/json application/xml application/linkset+json application/rss+xml image/svg+xml
</IfModule>

# ==========================================
# Browser caching
# ==========================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 week"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/markdown "access plus 1 hour"
    ExpiresByType application/rss+xml "access plus 1 hour"
    ExpiresByType text/plain "access plus 5 minutes"
    ExpiresByType application/json "access plus 5 minutes"
    ExpiresByType application/linkset+json "access plus 5 minutes"
    ExpiresByType application/xml "access plus 1 hour"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

AddDefaultCharset UTF-8
